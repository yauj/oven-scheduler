# Copy to .env for local testing of scripts/trigger_oven.py.
# Never commit a real .env file — these same values belong in GitHub
# Actions repo secrets (Settings -> Secrets and variables -> Actions),
# NOT in this file, for the production trigger.

SMARTHQ_USERNAME=you@example.com
SMARTHQ_REFRESH_TOKEN=paste-the-refresh-token-from-scripts/get_refresh_token.py
OVEN_MAC=AA:BB:CC:DD:EE:FF

# Optional overrides — defaults live in scripts/trigger_oven.py
# SMARTHQ_REGION=US
# OVEN_CAVITY=upper
# TARGET_HOUR=1
# TARGET_MINUTE=0
# WINDOW_MINUTES=7
# TARGET_TEMP=450
# FORCE=0
